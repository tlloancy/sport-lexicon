{
  "lexicon": 1,
  "id": "app.sport.performance",
  "defs": {
    "main": {
      "type": "record",
      "record": {
        "type": "object",
        "required": ["family", "discipline", "movement", "metricType", "videoHash", "createdAt"],
        "properties": {
          "family": { "type": "string" },
          "discipline": { "type": "string" },
          "movement": { "type": "string" },
          "metricType": {
            "type": "string",
            "enum": ["weight", "time", "distance", "score", "none"]
          },
          "value": { "type": "number" },
          "unit": {
            "type": "string",
            "enum": ["kg", "lb", "s", "m", "km", "pts"]
          },
          "videoHash": { "type": "string" },
          "chunkManifest": { "type": "string" },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
